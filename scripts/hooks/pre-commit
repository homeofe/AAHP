#!/usr/bin/env bash
# AAHP pre-commit hook - fast handoff gate.
#
# Runs: aahp verify --level precommit
#   Layer 1: MANIFEST checksum integrity
#   Layer 2: content-drift gate (code changed => STATUS.md + MANIFEST.json must change)
#
# This is intentionally fast (no TTL parse, no network). The full gate runs in
# pre-push and in CI.
#
# Escape hatch: AAHP_SKIP_VERIFY=1 git commit ...   (caught by the required CI
# check; do NOT use it to bypass CI). Never use `git commit --no-verify`.
#
# Installed by: scripts/install-hooks.sh

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || echo ".")"
VERIFY="$REPO_ROOT/scripts/verify-handoff.sh"

# Resolve the gate: prefer the vendored script (full AAHP checkout); otherwise
# fall back to the installed aahp CLI (npm-install consumer). If neither is
# available, skip. AAHP_SKIP_VERIFY=1 disables the CLI fallback locally (the
# vendored script honours the same escape hatch internally).
if [ -f "$VERIFY" ] || [ -x "$VERIFY" ]; then
    bash "$VERIFY" "$REPO_ROOT" --level precommit
elif [ "${AAHP_SKIP_VERIFY:-0}" != "1" ] && command -v npx >/dev/null 2>&1 && npx --no-install aahp --version >/dev/null 2>&1; then
    npx --no-install aahp verify "$REPO_ROOT" --level precommit
else
    echo "AAHP pre-commit: no verify-handoff.sh and no aahp CLI, skipping gate." >&2
    exit 0
fi
