{
  "name": "@elvatis_com/aahp",
  "version": "3.7.0",
  "description": "AI-to-AI Handoff Protocol - CLI tools for managing agent handoff files",
  "author": "Elvatis <emre.kohler@elvatis.com>",
  "bin": {
    "aahp": "bin/aahp.js"
  },
  "keywords": [
    "ai",
    "handoff",
    "protocol",
    "agent",
    "llm",
    "ai-agent",
    "context-handoff",
    "multi-agent"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/homeofe/AAHP.git"
  },
  "homepage": "https://github.com/homeofe/AAHP#readme",
  "bugs": {
    "url": "https://github.com/homeofe/AAHP/issues"
  },
  "files": [
    "bin/",
    "scripts/",
    "templates/",
    "schema/",
    "aahp.config.example.json",
    "CHANGELOG.md",
    "CONSTITUTION.md",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "type": "module",
  "scripts": {
    "check:changelog": "node scripts/check-changelog.mjs",
    "check:changelog-format": "node scripts/check-changelog-format.mjs",
    "check:version-sync": "node scripts/check-version-sync.mjs",
    "check:claims": "node scripts/check-claims.mjs",
    "check:forbidden-patterns": "node scripts/check-forbidden-patterns.mjs",
    "check:schema-doc-sync": "node scripts/check-schema-doc-sync.mjs",
    "check:doc-links": "node scripts/check-doc-links.mjs",
    "check:handoff": "node scripts/aahp-dashboard.mjs --check",
    "handoff:refresh": "node scripts/aahp-dashboard.mjs",
    "check": "npm run check:changelog && npm run check:changelog-format && npm run check:version-sync && npm run check:claims && npm run check:forbidden-patterns && npm run check:schema-doc-sync && npm run check:doc-links && npm run check:handoff",
    "doctor": "node bin/aahp.js doctor .",
    "test": "npx bats tests/",
    "prepublishOnly": "npm run check && npm run doctor && npm test"
  },
  "devDependencies": {
    "bats": "^1.13.0"
  }
}

